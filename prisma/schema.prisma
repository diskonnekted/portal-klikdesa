// Schema Prisma untuk Portal Web Desa Sijenggung
// Enhanced dengan semua fitur modern: SDGs, Live Statistics, Interactive Map, Community Engagement

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ===========================================
// ENUMS (Indonesian Naming Conventions)
// ===========================================

// ===========================================
// CORE MODELS
// ===========================================

// User Management dengan Enhanced Fields
model Pengguna {
  id          Int           @id @default(autoincrement())
  email       String        @unique 
  namaLengkap String        @map("nama_lengkap") 
  kataSandi   String        @map("kata_sandi") 
  nik         String?       @unique 
  telepon     String?       
  alamat      String?       
  peran       String @default("WARGA")
  avatar      String?       
  aktif       Boolean       @default(true)
  createdAt   DateTime      @default(now()) @map("created_at")
  updatedAt   DateTime      @updatedAt @map("updated_at")

  // Relations
  pengaduan          Pengaduan[]
  relawan            Relawan[]
  pollingSuara       PollingSuara[]
  crowdfundKontribusi CrowdfundKontribusi[]
  notifikasiUser     NotifikasiUser[]

  @@map("pengguna")
}

// Content Management - Berita
model Berita {
  id          Int      @id @default(autoincrement())
  judul       String   
  slug        String   @unique 
  ringkasan   String?  
  konten      String   
  gambar      String?  
  kategori    String   @default("umum") 
  tag         String?  
  penulis     String   
  status      String   @default("DRAFT")
  dipublikasi DateTime? @map("dipublikasi")
  viewCount   Int      @default(0) @map("view_count")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@map("berita")
}

// Content Management - Pengumuman
model Pengumuman {
  id          Int      @id @default(autoincrement())
  judul       String   
  konten      String   
  gambar      String?  
  prioritas   String @default("NORMAL")
  status      String   @default("DRAFT")
  dipublikasi DateTime? @map("dipublikasi")
  expiresAt   DateTime? @map("expires_at")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@map("pengumuman")
}

// Layanan Mandiri - Permohonan Layanan
model LayananPermohonan {
  id              Int              @id @default(autoincrement())
  namaPemohon     String           @map("nama_pemohon") 
  nikPemohon      String           @map("nik_pemohon") 
  emailPemohon    String           @map("email_pemohon") 
  teleponPemohon  String           @map("telepon_pemohon") 
  alamatLengkap   String           @map("alamat_lengkap") 
  jenisLayanan    String     @map("jenis_layanan")
  keterangan      String?          
  dokumen         String?          
  statusPermohonan String @map("status_permohonan") @default("MENUNGGU")
  idPelacakan     String           @unique @map("id_pelacakan") 
  tanggalPengajuan DateTime         @default(now()) @map("tanggal_pengajuan")
  tanggalUpdate   DateTime         @updatedAt @map("tanggal_update")

  @@map("layanan_permohonan")
}

// Transparansi Keuangan - APBDes
model APBDes {
  id             Int         @id @default(autoincrement())
  tahunAnggaran  String      @map("tahun_anggaran") 
  totalAnggaran  Decimal     @map("total_anggaran") 
  totalRealisasi Decimal?    @map("total_realisasi") 
  status         String @default("AKTIF")
  createdAt      DateTime    @default(now()) @map("created_at")
  updatedAt      DateTime    @updatedAt @map("updated_at")

  // Relations
  rincian APBDesRincian[]

  @@unique([tahunAnggaran])
  @@map("apbdes")
}

model APBDesRincian {
  id          Int      @id @default(autoincrement())
  apbdesId    Int      @map("apbdes_id")
  kategori    String   
  subKategori String?  @map("sub_kategori") 
  anggaran    Decimal  
  realisasi   Decimal? 
  persentase  Float?   
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  // Relations
  apbdes APBDes @relation(fields: [apbdesId], references: [id])

  @@unique([apbdesId, kategori, subKategori])
  @@map("apbdes_rincian")
}

// Pembangunan Desa - Proyek
model Proyek {
  id          Int         @id @default(autoincrement())
  nama        String      
  deskripsi   String      
  lokasi      String      
  anggaran    Decimal     
  progress    Float       @default(0) 
  status      String @default("PERENCANAAN")
  mulai       DateTime    
  selesai     DateTime?   
  koordinat   String?      // GPS coordinates
  createdAt   DateTime    @default(now()) @map("created_at")
  updatedAt   DateTime    @updatedAt @map("updated_at")

  // Relations
  galeri ProyekGaleri[]

  @@map("proyek")
}

model ProyekGaleri {
  id         Int      @id @default(autoincrement())
  proyekId   Int      @map("proyek_id")
  gambar     String   
  keterangan String?  
  createdAt  DateTime @default(now()) @map("created_at")

  // Relations
  proyek Proyek @relation(fields: [proyekId], references: [id])

  @@map("proyek_galeri")
}

// Kegiatan Masyarakat
model Kegiatan {
  id        Int              @id @default(autoincrement())
  nama      String           
  deskripsi String           
  kategori  String
  tanggal   DateTime         
  waktu     DateTime?        
  lokasi    String           
  koordinat String?           // GPS coordinates
  status    String   @default("AKTIF")
  createdAt DateTime         @default(now()) @map("created_at")
  updatedAt DateTime         @updatedAt @map("updated_at")

  @@map("kegiatan")
}

// ===========================================
// ENHANCED MODELS - NEW FEATURES
// ===========================================

// SDGs Progress Tracking
model SDGsProgress {
  id          Int      @id @default(autoincrement())
  goal        Int      // 1-17
  judul       String   
  deskripsi   String   
  progress    Float    @default(0)  // Percentage 0-100
  targetTahun Int      @map("target_tahun")
  satuan      String   
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  // Relations
  program Program[]

  @@unique([goal])
  @@map("sdgs_progress")
}

// Program Development
model Program {
  id            Int      @id @default(autoincrement())
  sdgsGoalId    Int      @map("sdgs_goal_id")
  namaProgram   String   @map("nama_program") 
  deskripsi     String   
  anggaran      Decimal  
  progress      Float    @default(0) 
  tanggalMulai  DateTime @map("tanggal_mulai") 
  tanggalSelesai DateTime? @map("tanggal_selesai") 
  penanggungJawab String  @map("penanggung_jawab") 
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  // Relations
  sdgsGoal SDGsProgress @relation(fields: [sdgsGoalId], references: [id])

  @@map("program")
}

// Interactive Map Locations
model LokasiInteraktif {
  id          Int         @id @default(autoincrement())
  nama        String      
  deskripsi   String?     
  jenis       String
  alamat      String      
  koordinat   String       // "latitude,longitude"
  telepon     String?     
  jamOperasi  String?     
  website     String?     
  gambar      String?     
  aktif       Boolean     @default(true)
  createdAt   DateTime    @default(now()) @map("created_at")
  updatedAt   DateTime    @updatedAt @map("updated_at")

  @@map("lokasi_interaktif")
}

// Community Polling System
model CommunityPoll {
  id          Int      @id @default(autoincrement())
  pertanyaan  String   
  deskripsi   String?  
  kategori    String   
  tanggalMulai DateTime @map("tanggal_mulai") 
  tanggalSelesai DateTime? @map("tanggal_selesai") 
  aktif       Boolean  @default(true)
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  // Relations
  pilihan PollingPilihan[]
  suara   PollingSuara[]

  @@map("community_poll")
}

model PollingPilihan {
  id      Int      @id @default(autoincrement())
  pollId  Int      @map("poll_id")
  pilihan String   
  urutan  Int      @default(0)
  createdAt DateTime @default(now()) @map("created_at")

  // Relations
  poll CommunityPoll @relation(fields: [pollId], references: [id])
  suara PollingSuara[]

  @@unique([pollId, urutan])
  @@map("polling_pilihan")
}

model PollingSuara {
  id        Int      @id @default(autoincrement())
  pollId    Int      @map("poll_id")
  pilihanId Int      @map("pilihan_id")
  penggunaId Int?    @map("pengguna_id")
  ipAlamat  String   @map("ip_alamat") 
  createdAt DateTime @default(now()) @map("created_at")

  // Relations
  poll    CommunityPoll @relation(fields: [pollId], references: [id])
  pilihan PollingPilihan @relation(fields: [pilihanId], references: [id])
  pengguna Pengguna?     @relation(fields: [penggunaId], references: [id])

  @@unique([pollId, ipAlamat]) // One vote per IP per poll
  @@map("polling_suara")
}

// Live Statistics
model LiveStatistics {
  id          Int      @id @default(autoincrement())
  kategori    String   
  judul       String   
  nilai       BigInt
  satuan      String   
  persenChange Float?  @map("persen_change") 
  lastUpdate  DateTime @default(now()) @map("last_update")

  @@unique([kategori, judul])
  @@map("live_statistics")
}

// Emergency Alerts
model EmergencyAlert {
  id          Int              @id @default(autoincrement())
  judul       String           
  pesan       String           
  tingkat     String            // LOW, MEDIUM, HIGH, CRITICAL
  kategori    String           
  lokasi      String?          
  koordinat   String?          
  expiresAt   DateTime?        @map("expires_at")
  aktif       Boolean          @default(true)
  createdAt   DateTime         @default(now()) @map("created_at")
  updatedAt   DateTime         @updatedAt @map("updated_at")

  @@map("emergency_alert")
}

// Weather Data
model WeatherData {
  id          Int      @id @default(autoincrement())
  suhu        Float
  kelembaban  Float
  tekanan     Float?
  kecepatanAngin Float?  @map("kecepatan_angin")
  arahAngin   String?  @map("arah_angin") 
  kondisi     String   
  deskripsi   String?  
  lastUpdate  DateTime @default(now()) @map("last_update")

  @@map("weather_data")
}

// Notifications
model Notifikasi {
  id          Int              @id @default(autoincrement())
  judul       String           
  pesan       String           
  jenis       String
  icon        String?          
  link        String?          
  global      Boolean          @default(false) // True untuk semua pengguna
  expiresAt   DateTime?        @map("expires_at")
  createdAt   DateTime         @default(now()) @map("created_at")

  // Relations
  notifikasiUser NotifikasiUser[]

  @@map("notifikasi")
}

model NotifikasiUser {
  id            Int         @id @default(autoincrement())
  notifikasiId  Int         @map("notifikasi_id")
  penggunaId    Int         @map("pengguna_id")
  dibaca        Boolean     @default(false)
  dibacaPada    DateTime?   @map("dibaca_pada")
  createdAt     DateTime    @default(now()) @map("created_at")

  // Relations
  notifikasi Notifikasi @relation(fields: [notifikasiId], references: [id])
  pengguna   Pengguna   @relation(fields: [penggunaId], references: [id])

  @@unique([notifikasiId, penggunaId])
  @@map("notifikasi_user")
}

// Volunteer Management
model Relawan {
  id            Int          @id @default(autoincrement())
  penggunaId    Int          @map("pengguna_id")
  namaLengkap   String       @map("nama_lengkap") 
  nik           String       
  email         String       
  telepon       String       
  alamat        String       
  keahlian      String?      
  pengalaman    String?      
  ketersediaan String?      
  status        String @default("TERDAFTAR")
  createdAt     DateTime     @default(now()) @map("created_at")
  updatedAt     DateTime     @updatedAt @map("updated_at")

  // Relations
  pengguna Pengguna @relation(fields: [penggunaId], references: [id])

  @@map("relawan")
}

// Crowdfunding Platform
model Crowdfunding {
  id          Int               @id @default(autoincrement())
  judul       String            
  deskripsi   String            
  gambar      String?           
  target      Decimal           
  terkumpul   Decimal           @default(0) 
  deadline    DateTime          
  kategori    String            
  status      String @default("PENDAFTARAN")
  createdAt   DateTime          @default(now()) @map("created_at")
  updatedAt   DateTime          @updatedAt @map("updated_at")

  // Relations
  kontribusi CrowdfundKontribusi[]

  @@map("crowdfunding")
}

model CrowdfundKontribusi {
  id           Int      @id @default(autoincrement())
  crowdfundingId Int     @map("crowdfunding_id")
  penggunaId     Int?    @map("pengguna_id")
  namaDonatur   String  @map("nama_donatur") 
  emailDonatur  String  @map("email_donatur") 
  jumlah        Decimal 
  pesan         String? 
  anonim        Boolean @default(false)
  createdAt     DateTime @default(now()) @map("created_at")

  // Relations
  crowdfunding Crowdfunding @relation(fields: [crowdfundingId], references: [id])
  pengguna     Pengguna?    @relation(fields: [penggunaId], references: [id])

  @@map("crowdfund_kontribusi")
}

// ===========================================
// LEGACY MODELS (Enhanced)
// ===========================================

// Pengaduan System (Enhanced)
model Pengaduan {
  id          Int              @id @default(autoincrement())
  userId      Int?             @map("user_id")
  nama        String           
  email       String           
  telepon     String           
  kategori    String           
  subjek      String           
  pesan       String           
  lokasi      String?          
  koordinat   String?          
  gambar      String?          
  status      String  @default("MENUNGGU")
  tiketId     String           @unique 
  createdAt   DateTime         @default(now()) @map("created_at")
  updatedAt   DateTime         @updatedAt @map("updated_at")

  // Relations
  user Pengguna? @relation(fields: [userId], references: [id])

  @@map("pengaduan")
}

// Media Management
model Media {
  id          Int      @id @default(autoincrement())
  nama        String   
  path        String   
  ukuran      Int      // bytes
  tipe        String   
  alt         String?  
  kategori    String?  
  createdAt   DateTime @default(now()) @map("created_at")

  @@map("media")
}

// Configuration
model Konfigurasi {
  id        Int    @id @default(autoincrement())
  kunci     String @unique 
  nilai     String 
  kategori  String? 
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("konfigurasi")
}

